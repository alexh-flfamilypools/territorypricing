# Copy this file to .env and fill in your values.

# Google Maps API key — enable: Maps JavaScript API, Places API, Drawing Library.
# Lock the key to your domain in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# Firebase — create a project at console.firebase.google.com, add a web app,
# then copy the config values here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Editor PIN — anyone with this PIN can make changes to the map.
# Share it only with your 3 editors.
VITE_EDITOR_PIN=
